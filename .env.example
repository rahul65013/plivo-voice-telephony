# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# Your EC2 public domain (set after EC2 is running)
# e.g. https://calls.yourdomain.com  OR  https://ec2-xx-xx-xx-xx.compute.amazonaws.com
SERVER_BASE_URL=https://YOUR_EC2_DOMAIN_OR_IP

# ── Plivo ─────────────────────────────────────────────────────────────────────
PLIVO_AUTH_ID=YOUR_PLIVO_AUTH_ID
PLIVO_AUTH_TOKEN=YOUR_PLIVO_AUTH_TOKEN
PLIVO_FROM_NUMBER=+1XXXXXXXXXX        # Your Plivo DID number

# ── Sarvam AI ─────────────────────────────────────────────────────────────────
SARVAM_API_KEY=YOUR_SARVAM_API_KEY
SARVAM_LANGUAGE=en-IN

# ── Your Backend ──────────────────────────────────────────────────────────────
# POST {callUUID, transcript, userText} → returns { audioUrl: "https://..." }
BACKEND_API_URL=https://your-backend.com/api/call-response
BACKEND_API_KEY=YOUR_BACKEND_API_KEY    # optional, sent as Bearer token
